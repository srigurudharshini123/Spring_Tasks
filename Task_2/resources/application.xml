<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
       
       
       <bean id="car1" class="bean.Car">
       <property name="num" value="65675"/>
        <property name="brand" value="Audi"/>
        <property name="rate" value="90000.90"/>
        <property name="eng" ref="engine1"/>
       </bean>
       
       
       <bean id="engine1" class="bean.Engine">
       <property name="work" value="true"/>
        <property name="capacity" value="40"/>
       </bean>
       
       
       
       
       
       
       
       
       </beans>
       
