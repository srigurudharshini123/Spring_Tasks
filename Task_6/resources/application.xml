<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

<bean id="mob1" class="bean.Mobile" autowire="byType">
<property name="id" value="111"/>
<property name="brand" value="vivo"/>
<property name="price" value="100000.90"/>
</bean>

<!-- byType means just create obj using class=bean.Battery don't dare about id name-->
<bean id="bat1" class="bean.Battery">
<property name="gb" value="600"/>
<property name="work" value="Working well..."/>
</bean>




</beans>
