<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

<bean id="pre1" class="bean.Printer" scope="singleton">
<property name="pages" value="64"/>
<property name="filename" value="book.pdf"/>
</bean>


<bean id="pre2" class="bean.Printer" scope="prototype">
<property name="pages" value="66"/>
<property name="filename" value="maths.pdf"/>
</bean>




</beans>
